{
  "name": "Flags",
  "type": "flags",
  "values": [
    {
      "name": "name",
      "type": "std::string",
      "required": true,
      "description": "gateway name"
    },
    {
      "name": "config_file",
      "type": "std::string",
      "validator": "roq::flags::validators::Path",
      "required": true,
      "description": "config file (path)"
    },
    {
      "name": "channel_ids",
      "type": "std::vector<uint16_t>",
      "required": true,
      "description": "Comma-separated list of multicast channels, e.g. 310"
    },
    {
      "name": "secdef_config_file",
      "type": "std::string",
      "validator": "roq::flags::validators::Path",
      "description": "config file (path)"
    },
    {
      "name": "symbols",
      "type": "std::vector<std::string>",
      "description": "Comma-separated list of symbols (regex)"
    },
    {
      "name": "cache_all_reference_data",
      "type": "bool",
      "default": false,
      "description": "Cache all reference data?"
    },
    {
      "name": "event_log_dir",
      "type": "std::string",
      "description": "event-log directory"
    },
    {
      "name": "output_file",
      "type": "std::string",
      "required": true,
      "description": "output file"
    },
    {
      "name": "event_log_buffer_size",
      "type": "uint32_t",
      "required": true,
      "default": 134217728,
      "description": "event-log output buffer size (bytes)"
    },
    {
      "name": "event_log_compression_level",
      "type": "uint32_t",
      "required": true,
      "default": 4,
      "description": "event-log compression level"
    },
    {
      "name": "encode_buffer_size",
      "type": "uint32_t",
      "required": true,
      "default": 16777216,
      "description": "Encode buffer size"
    }
  ]
}
