{
  "name": "FIX",
  "type": "flags",
  "values": [
    {
      "name": "fix_uri",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI<std::string>",
      "default": "tcp://test.deribit.com:9881",
      "description": "FIX end-point (URI)"
    },
    {
      "name": "fix_ping_freq",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "5s",
      "description": "ping frequency"
    },
    {
      "name": "fix_request_timeout",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "15s",
      "description": "request timeout"
    },
    {
      "name": "fix_cancel_on_disconnect",
      "type": "bool",
      "default": true,
      "description": "cancel orders on disconnect? (bool)"
    },
    {
      "name": "fix_market_data_max_subscriptions_per_stream",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 256,
      "description": "max subscriptions per connection (count)"
    },
    {
      "name": "fix_market_data_request_max_size",
      "type": "uint32_t",
      "default": 56,
      "description": "max batch size (it appears there is a limit)"
    },
    {
      "name": "fix_market_data_market_depth",
      "type": "uint32_t",
      "default": 20,
      "description": "market depth (see deribit documentation)"
    },
    {
      "name": "fix_debug",
      "type": "bool",
      "default": false,
      "description": "log fix messages?"
    },
    {
      "name": "fix_continue_from_parse_exception",
      "type": "bool",
      "default": false,
      "description": "continue if message can't be parsed?"
    },
    {
      "name": "fix_terminate_on_market_data_request_reject",
      "type": "bool",
      "default": false,
      "description": "terminate if market data request has been rejected?"
    },
    {
      "name": "fix_test_order_disconnect",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "{}",
      "description": "TEST disconnect order stream after this period"
    },
    {
      "name": "fix_test_order_logon",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "{}",
      "description": "TEST logon order stream after this period"
    },
    {
      "name": "fix_test_market_data_disconnect",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "{}",
      "description": "TEST disconnect market data stream after this period"
    }
  ]
}
