{
  "name": "Multicast",
  "type": "flags",
  "values": [
    {
      "name": "multicast_config_file",
      "type": "std::string",
      "validator": "roq::core::flags::Path<std::string>",
      "description": "config file (path)"
    },
    {
      "name": "multicast_channel_id",
      "type": "std::string",
      "description": "Multicast channel, e.g. 310"
    },
    {
      "name": "multicast_local_interface",
      "type": "std::string",
      "description": "Multicast local interface"
    },
    {
      "name": "multicast_timeout",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "90s",
      "description": "Timeout when waiting for snapshot"
    },
    {
      "name": "multicast_is_premium",
      "type": "bool",
      "description": "Is the feed premium? (will join the recovery channels)"
    }
  ]
}
