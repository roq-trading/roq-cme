{
  "name": "iLink",
  "type": "flags",
  "values": [
    {
      "name": "ilink_config_file",
      "type": "std::string",
      "validator": "roq::core::flags::Path",
      "description": "config file (path)"
    },
    {
      "name": "ilink_market_segments",
      "type": "std::vector<std::string>",
      "description": "Comma-separated list of market segments, e.g. 70"
    },
    {
      "name": "test_uri",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI",
      "default": "tcp://69.50.112.179:65301",
      "description": "MSGW end-point (URI)"
    },
    {
      "name": "decode_buffer_size",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 10485760,
      "description": "decode buffer size"
    }
  ]
}
