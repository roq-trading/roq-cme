{
  "name": "WebSocket",
  "type": "flags",
  "values": [
    {
      "name": "ws_uri",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI<std::string>",
      "default": "wss://test.deribit.com/ws/api/v2",
      "description": "WebSocket end-point (URI)"
    },
    {
      "name": "ws_ping_freq",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "5s",
      "description": "ping frequency"
    },
    {
      "name": "ws_request_timeout",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "15s",
      "description": "request timeout"
    },
    {
      "name": "ws_market_data_max_subscriptions_per_stream",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 256,
      "description": "max subscriptions per connection (count)"
    },
    {
      "name": "ws_max_trades",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 100,
      "description": "max number of trades for historical lookup (count)"
    },
    {
      "name": "ws_ticker_interval",
      "type": "std::string",
      "default": "100ms",
      "description": "ticker interval"
    },
    {
      "name": "ws_allow_errors",
      "type": "bool",
      "description": "allow errors (debug)"
    }
  ]
}
