{
  "name": "Config",
  "type": "flags",
  "values": [
    {
      "name": "config_file",
      "type": "std::string",
      "validator": "roq::core::flags::Path",
      "description": "config file (path)"
    },
    {
      "name": "secrets_file",
      "type": "std::string",
      "validator": "roq::core::flags::Path",
      "description": "secrets file (path, optional)"
    },
    {
      "name": "exchange",
      "type": "std::string",
      "validator": "roq::core::flags::NonEmpty",
      "default": "deribit",
      "description": "exchange identifier (string)"
    },
    {
      "name": "mbp_allow_price_inversion",
      "type": "bool",
      "default": true,
      "description": "allow price inversion?"
    }
  ]
}
