{
  "name": "Flags",
  "type": "flags",
  "values": [
    {
      "name": "type",
      "type": "std::string",
      "required": true,
      "description": "type of output, e.g. tcpdump"
    },
    {
      "name": "config_file",
      "type": "std::string",
      "validator": "roq::flags::validators::Path",
